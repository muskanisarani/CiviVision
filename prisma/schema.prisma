datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  mobile       String        @unique
  passwordHash String
  city         String
  state        String
  ward         String        @default("Sector 5")
  language     String        @default("en")
  avatarType   String        @default("badge") // "badge" or "upload"
  avatarBadge  String        @default("initials")
  avatarUrl    String?
  role         String        @default("user") // "user" or "admin"
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  complaints   Complaint[]
  notifications Notification[]
}

model Complaint {
  id           String        @id @default(uuid())
  category     String
  details      String
  status       String        @default("Pending") // "Pending", "In Progress", "Resolved"
  photoUrl     String?
  latitude     Float?
  longitude    Float?
  locationName String?
  durationDays String        @default("Today")
  rating       Int?          // 1 to 5 stars
  comment      String?       // Feedback review comment
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  // Relations
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id           String        @id @default(uuid())
  title        String
  message      String
  read         Boolean       @default(false)
  createdAt    DateTime      @default(now())
  
  // Relations
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Toilet {
  id                String   @id @default(uuid())
  name              String
  address           String
  latitude          Float
  longitude         Float
  rating            Float    @default(4.0)
  votes             Int      @default(1)
  fee               String   @default("Free")
  type              String   @default("Unisex")
  hasVendingMachine Boolean  @default(false)
  status            String   @default("Clean")
  createdAt         DateTime @default(now())
}

model Alert {
  id        String   @id @default(uuid())
  title     String
  category  String
  date      String
  severity  String   @default("info") // "info", "warning", "danger"
  details   String
  createdAt DateTime @default(now())
}
